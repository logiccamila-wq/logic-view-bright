# ========================================
# NEON DATABASE (Principal)
# ========================================
# COMO OBTER:
# 1. Acesse: https://console.neon.tech/app/projects
# 2. Selecione: optilog-app (logiccamila@gmail.com)
# 3. Branch: main
# 4. Connection Details > Connection string
# 5. Copie e cole abaixo

DATABASE_URL=postgresql://seu-usuario:senha@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://seu-usuario:senha@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require

# ========================================
# NEON REST API (Opcional)
# ========================================
# Para queries serverless via HTTP
