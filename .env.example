# Environment variables — Logic View Bright
# Copy this file to .env.local and fill in the values.
# Do NOT commit .env.local or any file with real secrets.

# ──────────────────────────────────────────────────────
# CLIENT-SIDE (VITE_ prefix) — safe for frontend bundle
# Set these in Vercel Dashboard → Settings → Environment Variables
# ──────────────────────────────────────────────────────

# Supabase project URL (from Supabase Dashboard → Settings → API → Project URL)
VITE_SUPABASE_URL=

# Supabase anon/public key (from Supabase Dashboard → Settings → API → anon/public)
# This key is safe to expose in the browser; RLS policies protect the data.
VITE_SUPABASE_ANON_KEY=

# Public URL of the deployed application
VITE_APP_URL=

# EmailJS integration (optional)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Map / Routing API keys (optional)
VITE_OPENROUTE_API_KEY=
VITE_TOMTOM_API_KEY=

# ──────────────────────────────────────────────────────
# SERVER-SIDE ONLY — never use VITE_ prefix for these!
# For local scripts (seed, create-users, etc.) only.
# In production, set these in Supabase Dashboard → Settings → Edge Functions.
# NEVER add these to Vercel or any frontend host.
# ──────────────────────────────────────────────────────

# Supabase service role key — bypasses RLS, keep secret!
# (from Supabase Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project URL (no VITE_ prefix — used by server scripts)
SUPABASE_URL=

# ──────────────────────────────────────────────────────
# E2E TESTING (Playwright) — never commit real values!
# Set these in your .env.local for local runs, and in
# GitHub → Settings → Secrets → Actions for CI.
#
# ⚠️  SECURITY REMINDERS:
#   • Do NOT use SUPABASE_SERVICE_ROLE_KEY or any JWT secret here.
#   • Only the anon/public key is needed for browser-side tests.
#   • If you accidentally commit real credentials, rotate them
#     immediately in Supabase Dashboard → Settings → API.
# ──────────────────────────────────────────────────────

# Full URL of the running application under test (e.g. http://localhost:3000)
TEST_BASE_URL=http://localhost:3000

# Admin (or test-user) credentials for E2E login flows
TEST_ADMIN_EMAIL=your-test-user@example.com
TEST_ADMIN_PASSWORD=your-test-password

# Supabase anon/public key (same value as VITE_SUPABASE_ANON_KEY above)
# Used by the programmatic login helper in tests/e2e/lib/supabase-client.ts
SUPABASE_ANON_KEY=