# Environment variables — Logic View Bright (Azure-only baseline)
# Copy this file to .env.local and fill in the values.
# Do NOT commit .env.local or any file with real secrets.

# -----------------------------
# CLIENT-SIDE (safe for bundle)
# Configure in Azure Static Web Apps -> Configuration
# -----------------------------

# Public URL of the deployed application
VITE_APP_URL=

# Base URL for Azure Functions HTTP APIs
VITE_API_BASE_URL=

# Optional external integrations
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=
VITE_OPENROUTE_API_KEY=
VITE_TOMTOM_API_KEY=

# -----------------------------
# SERVER-SIDE (never expose)
# Configure in Azure Functions / Container Apps / App Service
# -----------------------------

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure Database for PostgreSQL (or Azure SQL equivalent)
AZURE_POSTGRES_HOST=
AZURE_POSTGRES_PORT=5432
AZURE_POSTGRES_DB=
AZURE_POSTGRES_USER=
AZURE_POSTGRES_PASSWORD=

# Azure Storage
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=
AZURE_STORAGE_CONNECTION_STRING=

# Security / auth integration (exemplo com Entra ID)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_JWT_SECRET=
AZURE_JWT_EXPIRES_IN=7d

# Optional: proxy from runtime /invoke/* to external Azure Functions host
AZURE_FUNCTIONS_BASE_URL=
AZURE_FUNCTIONS_API_KEY=

# CORS
ALLOWED_ORIGINS=