# Environment variables — Logic View Bright
# Copy this file to .env.local and fill in the values.
# Do NOT commit .env.local or any file with real secrets.

# ──────────────────────────────────────────────────────
# CLIENT-SIDE (VITE_ prefix) — safe for frontend bundle
# Set these in Vercel Dashboard → Settings → Environment Variables
# ──────────────────────────────────────────────────────

# Supabase project URL (from Supabase Dashboard → Settings → API → Project URL)
VITE_SUPABASE_URL=

# Supabase anon/public key (from Supabase Dashboard → Settings → API → anon/public)
# This key is safe to expose in the browser; RLS policies protect the data.
VITE_SUPABASE_ANON_KEY=

# Public URL of the deployed application
VITE_APP_URL=

# EmailJS integration (optional)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Map / Routing API keys (optional)
VITE_OPENROUTE_API_KEY=
VITE_TOMTOM_API_KEY=

# ──────────────────────────────────────────────────────
# SERVER-SIDE ONLY — never use VITE_ prefix for these!
# For local scripts (seed, create-users, etc.) only.
# In production, set these in Supabase Dashboard → Settings → Edge Functions.
# NEVER add these to Vercel or any frontend host.
# ──────────────────────────────────────────────────────

# Supabase service role key — bypasses RLS, keep secret!
# (from Supabase Dashboard → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project URL (no VITE_ prefix — used by server scripts)
SUPABASE_URL=