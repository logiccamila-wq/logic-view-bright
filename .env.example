###############################################
# Exemplo de variáveis de ambiente (raiz)
# Copie para .env.local e ajuste os valores
###############################################

# App (URLs)
NEXT_PUBLIC_API_URL=http://localhost:3011

# Auth/JWT
JWT_SECRET=troque-por-um-segredo-seguro

# Banco (Neon/Vercel Postgres)
DATABASE_URL=postgresql://usuario:senha@host:5432/database?sslmode=require
DATABASE_URL_UNPOOLED=
NEON_DATA_API_URL=https://SEU_WORKSPACE-xxxxx.neon.tech
NEXT_PUBLIC_NEON_REST_URL=

# IA
OPENAI_API_KEY=
AI_PROVIDER=openai
NEXT_PUBLIC_AI_PROVIDER=openai

# Firebase (LEGADO desativado)
NEXT_PUBLIC_DISABLE_FIREBASE=1
NEXT_PUBLIC_AI_PROVIDERS=ChatGPT

# Backend (opcional para modo standalone)
BACKEND_PORT=3011